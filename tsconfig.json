{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "proxy.ts",
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/login/**/*.tsx",
    "src/app/loading/**/*.tsx",
    "src/app/dashboard/layout.tsx",
    "src/app/dashboard/page.tsx",
    "src/app/companies/page.tsx",
    "src/app/companies/[id]/page.tsx",
    "src/app/settings/page.tsx",
    "src/app/meta-ads/page.tsx",
    "src/app/api/auth/**/*.ts",
    "src/app/api/dashboard/control-center/route.ts",
    "src/app/api/dashboard/sales/route.ts",
    "src/app/api/v1/companies/route.ts",
    "src/app/api/v1/companies/[companyId]/route.ts",
    "src/app/api/cron/sync-meta-ads/route.ts",
    "src/app/api/meta/**/*.ts",
    "src/app/api/sync/all-channels/route.ts"
  ],
  "exclude": [
    "node_modules",
    ".next/types/**",
    ".next/dev/types/**",
    "src/api/**",
    "src/services/**",
    "src/repositories/**",
    "src/types/**",
    "src/hooks/useRevenue.ts",
    "src/components/revenue/**",
    "src/core/**",
    "src/lib/ai/**",
    "src/lib/whatsapp/ai-analysis.ts",
    "src/app/companies/*/ai-leads/**",
    "src/app/companies/*/crm/**",
    "src/app/companies/*/data-health/**",
    "src/app/companies/*/financeiro/**",
    "src/app/companies/*/integracoes/**",
    "src/app/companies/*/whatsapp/**",
    "src/app/api/v1/companies/*/integrations/**",
    "src/app/api/v1/companies/*/knowledge/**",
    "src/app/api/v1/companies/*/leads/**",
    "src/app/api/v1/companies/*/pipelines/**",
    "src/app/api/v1/companies/*/sales/**",
    "src/app/api/v1/companies/*/whatsapp/**",
    "src/app/api/v1/integrations/**",
    "src/app/api/webhooks/lead-intake/**",
    "src/app/api/webhooks/whatsapp/**",
    "src/app/api/revenue/_router.ts",
    "src/app/api/workflows/_router.ts"
  ]
}
