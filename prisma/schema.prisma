generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdChannel {
  META
  GOOGLE
  TIKTOK
  SHOPEE
}

enum ConversionSourceType {
  SHOPIFY
  CRM
  TYPEFORM
  API
  MANUAL
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// --- Empresas (Multi-tenancy) ---

model Company {
  id              String   @id @default(cuid())
  name            String
  segment         String   @default("other")
  logo            String?
  status          String   @default("active")
  responsibleName String?
  phone           String?
  whatsapp        String?
  city            String?
  state           String?
  website         String?
  instagram       String?
  facebook        String?
  tiktok          String?
  shopee          String?
  googleBusiness  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                 CompanyUser[]
  leads                 Lead[]
  adAccounts            AdAccount[]
  campaigns             Campaign[]
  conversions           ConversionEvent[]
  whatsappConversations WhatsAppConversation[]
  sales                 Sale[]
  integrations          CompanyIntegration[]
  auditLogs             AuditLog[]
  knowledge             CompanyKnowledge?
  leadInteractions      LeadInteraction[]

  // MASTER 06: Revenue Engine
  revenueSales          RevenueSale[]
  revenueSources        RevenueSource[]
  revenueProducts       RevenueProduct[]
  revenueIndicators     RevenueIndicator[]
  revenueLossReasons    RevenueLossReason[]
  revenueTimelines      RevenueTimeline[]
  revenueGoals          RevenueGoal[]
  revenueForecasts      RevenueForecast[]
  revenueCommissions    RevenueCommission[]
  revenueScores         RevenueScore[]

  // MASTER 06: Communication Hub
  attendanceStatuses    AttendanceStatus[]
  attendances           Attendance[]
  attendanceHistories   AttendanceHistory[]
  reminders             Reminder[]
  followUps             FollowUp[]
  lossReasons           LossReason[]
  saleResults           SaleResult[]
  salesGoals            SalesGoal[]
  notifications         Notification[]
  attendanceQueues      AttendanceQueue[]

  @@index([status])
  @@index([segment])
}

// --- Auth (NextAuth) ---

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  defaultCompanyId String?
  accounts         Account[]
  sessions         Session[]
  companyUsers     CompanyUser[]
  auditLogs        AuditLog[]
  assignedAttendances   Attendance[] @relation("AttendanceAttendant")
  createdAttendances    Attendance[] @relation("AttendanceCreator")
  attendanceHistoryEntries AttendanceHistory[]
  remindersAssigned     Reminder[]
  followUpsAssigned     FollowUp[]
  notificationsReceived Notification[]
  createdAt        DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Permissões ---

model CompanyUser {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("analyst")
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions CompanyUserPermission[]
  auditLogs   AuditLog[]

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([role])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  category    String

  companyUsers CompanyUserPermission[]
}

model CompanyUserPermission {
  id            String   @id @default(cuid())
  companyUserId String
  permissionId  String
  grantedAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  permission  Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, permissionId])
}

// --- Ad accounts / campaigns / metrics ---

model AdAccount {
  id                String    @id @default(cuid())
  channel           AdChannel
  externalAccountId String
  name              String
  loginCustomerId   String? // Google Ads MCC, quando aplicável
  accessToken       String?
  refreshToken      String?
  lastSyncedAt      DateTime?
  companyId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaigns Campaign[]
  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([channel, externalAccountId])
  @@index([companyId])
  @@index([channel, companyId])
}

model Campaign {
  id                 String    @id @default(cuid())
  adAccountId        String
  adAccount          AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  externalCampaignId String
  name               String
  objective          String?
  companyId          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  snapshots       MetricSnapshot[]
  conversions     ConversionEvent[] @relation("ConversionsToCampaign")
  alerts          Alert[]
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads           Lead[]
  sales           Sale[]
  revenueSales    RevenueSale[]     @relation("RevenueSalesToCampaign")
  attendances     Attendance[]

  @@unique([adAccountId, externalCampaignId])
  @@index([companyId])
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Decimal? @db.Decimal(12, 2)
  raw             Json? // payload bruto da API pra auditoria/debug
  createdAt       DateTime @default(now())

  @@unique([campaignId, date])
}

// --- Conversões offline (de qualquer origem) ---

model ConversionEvent {
  id             String               @id @default(cuid())
  campaignId     String?
  campaign       Campaign?            @relation("ConversionsToCampaign", fields: [campaignId], references: [id], onDelete: SetNull)
  channel        AdChannel
  sourceType     ConversionSourceType
  amount         Decimal?             @db.Decimal(12, 2)
  externalId     String?
  metadata       Json?
  pushBackStatus String?
  pushBackError  String?
  companyId      String?
  utm_source     String?
  utm_medium     String?
  utm_campaign   String?
  utm_term       String?
  utm_content    String?
  device         String?
  browser        String?
  os             String?
  createdAt      DateTime             @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([channel])
  @@index([companyId])
  @@index([createdAt])
  @@index([companyId, createdAt])
  @@index([companyId, channel])
}

// --- Alertas ---

model Alert {
  id           String        @id @default(cuid())
  campaignId   String?
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  severity     AlertSeverity
  type         String // "cpa_spike", "ctr_drop", "no_conversions", etc
  message      String
  threshold    Decimal?      @db.Decimal(12, 4)
  currentValue Decimal?      @db.Decimal(12, 4)
  dismissedAt  DateTime?
  createdAt    DateTime      @default(now())

  @@index([campaignId])
  @@index([severity])
  @@index([createdAt])
}

// --- Communication Hub ---

enum AttendanceResultType {
  VENDA_REALIZADA
  VENDA_PERDIDA
  EM_NEGOCIACAO
  RETORNAR_DEPOIS
  CANCELADO
  POS_VENDA
}

enum ReminderTriggerType {
  STUCK_2H
  STUCK_24H
  STUCK_48H
  NO_RESULT
  NO_RESPONSIBLE
  WAITING_RETURN
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SCHEDULED
  TRIGGERED
  COMPLETED
  CANCELED
}

enum FollowUpStatus {
  PENDING
  SCHEDULED
  DONE
  MISSED
  CANCELED
}

enum NotificationChannel {
  INTERNAL
  PUSH
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum QueueItemStatus {
  WAITING
  IN_PROGRESS
  DONE
  FAILED
  CANCELED
}

model AttendanceStatus {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  description String?
  color       String?
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([isActive])
  @@index([sortOrder])
}

model Attendance {
  id                     String   @id @default(cuid())
  companyId              String
  leadId                 String?
  campaignId             String?
  statusId               String
  whatsappConversationId  String?
  attendantId            String?
  creatorId              String?

  clientName             String
  clientPhone            String
  clientEmail            String?
  origin                 String?
  channel                String?
  campaignName           String?
  adName                 String?
  creativeName           String?
  productName            String?
  responsibleName        String?
  tenantName             String?

  priority               String   @default("normal")
  currentQueuePosition   Int?

  startedAt              DateTime @default(now())
  firstContactAt         DateTime?
  lastActivityAt         DateTime?
  dueAt                  DateTime?
  finishedAt             DateTime?
  responseTimeSeconds    Int?
  totalHandlingSeconds   Int?

  notes                  String?
  customFields           Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  company                Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead                   Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign               Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  status                 AttendanceStatus      @relation(fields: [statusId], references: [id], onDelete: Restrict)
  whatsappConversation   WhatsAppConversation? @relation(fields: [whatsappConversationId], references: [id], onDelete: SetNull)
  attendant              User?                 @relation("AttendanceAttendant", fields: [attendantId], references: [id], onDelete: SetNull)
  creator                User?                 @relation("AttendanceCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  histories              AttendanceHistory[]
  reminders              Reminder[]
  followUps              FollowUp[]
  notifications          Notification[]
  queueItem              AttendanceQueue?
  saleResult             SaleResult?

  @@index([companyId])
  @@index([statusId])
  @@index([leadId])
  @@index([campaignId])
  @@index([attendantId])
  @@index([creatorId])
  @@index([startedAt])
  @@index([createdAt])
  @@index([companyId, statusId])
  @@index([companyId, attendantId])
}

model AttendanceHistory {
  id               String   @id @default(cuid())
  companyId        String
  attendanceId     String
  leadId           String?
  eventType        String
  eventDescription String
  previousValue    String?
  newValue         String?
  userId           String?
  userEmail        String?
  metadata         Json?
  createdAt        DateTime @default(now())

  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance       Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  lead             Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user             User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([attendanceId])
  @@index([leadId])
  @@index([eventType])
  @@index([createdAt])
}

model Reminder {
  id              String            @id @default(cuid())
  companyId       String
  attendanceId    String?
  leadId          String?
  assignedToId    String?

  triggerType     ReminderTriggerType
  status          ReminderStatus    @default(PENDING)
  title           String
  description     String?
  scheduledAt     DateTime
  triggeredAt     DateTime?
  completedAt     DateTime?
  notes           String?
  customFields    Json?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance      Attendance?       @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  lead            Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo      User?             @relation("ReminderAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notifications   Notification[]

  @@index([companyId])
  @@index([attendanceId])
  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledAt])
  @@index([companyId, status])
  @@index([companyId, scheduledAt])
}

model FollowUp {
  id              String          @id @default(cuid())
  companyId       String
  attendanceId    String?
  leadId          String?
  assignedToId    String?

  status          FollowUpStatus  @default(PENDING)
  title           String
  description     String?
  scheduledFor    DateTime
  completedAt     DateTime?
  notes           String?
  customFields    Json?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance      Attendance?     @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  lead            Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo      User?           @relation("FollowUpAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notifications   Notification[]

  @@index([companyId])
  @@index([attendanceId])
  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledFor])
  @@index([companyId, status])
  @@index([companyId, scheduledFor])
}

model LossReason {
  id            String               @id @default(cuid())
  companyId     String
  reason        RevenueLossReasonType
  name          String
  description   String?
  displayOrder  Int                  @default(0)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  saleResults   SaleResult[]

  @@unique([companyId, reason])
  @@index([companyId])
  @@index([isActive])
  @@index([displayOrder])
}

model SaleResult {
  id             String              @id @default(cuid())
  companyId      String
  attendanceId   String             @unique
  leadId         String?
  revenueSaleId  String?            @unique
  lossReasonId   String?

  resultType     AttendanceResultType
  amount         Decimal?           @db.Decimal(12, 2)
  productName    String?
  paymentMethod  String?
  paymentDate    DateTime?
  observation    String?
  resultDate     DateTime           @default(now())
  resultTime     String?
  customFields   Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance     Attendance         @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  revenueSale    RevenueSale?       @relation(fields: [revenueSaleId], references: [id], onDelete: SetNull)
  lossReason     LossReason?        @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([leadId])
  @@index([revenueSaleId])
  @@index([lossReasonId])
  @@index([resultType])
  @@index([resultDate])
  @@index([companyId, resultType])
}

model SalesGoal {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  description     String?
  metricType      String
  targetValue     Decimal  @db.Decimal(12, 2)
  currentValue    Decimal  @db.Decimal(12, 2) @default(0)
  progressPercent Decimal  @db.Decimal(5, 2) @default(0)
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active")
  notes           String?
  customFields    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([metricType])
  @@index([startDate])
  @@index([endDate])
}

model Notification {
  id               String             @id @default(cuid())
  companyId        String
  attendanceId     String?
  reminderId       String?
  followUpId       String?
  recipientUserId  String?

  channel          NotificationChannel
  status           NotificationStatus @default(PENDING)
  type             String
  title            String
  message          String
  payload          Json?
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  errorMessage     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance       Attendance?        @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  reminder         Reminder?          @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  followUp         FollowUp?          @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  recipientUser    User?              @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([attendanceId])
  @@index([reminderId])
  @@index([followUpId])
  @@index([recipientUserId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([companyId, status])
}

model AttendanceQueue {
  id                String          @id @default(cuid())
  companyId         String
  attendanceId      String          @unique
  queueName         String          @default("default")
  queueStatus       QueueItemStatus @default(WAITING)
  position          Int             @default(0)
  priority          Int             @default(0)
  queuedAt          DateTime        @default(now())
  scheduledFor      DateTime?
  startedAt         DateTime?
  processedAt       DateTime?
  estimatedWaitSeconds Int?
  notes             String?
  customFields      Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance        Attendance      @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([attendanceId])
  @@index([queueStatus])
  @@index([queueName])
  @@index([queuedAt])
  @@index([position])
  @@index([companyId, queueStatus])
}

// --- Leads (CRM) ---

model Lead {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  email           String?
  phone           String?
  whatsapp        String?
  source          String   @default("organic")
  campaign        String?
  adSet           String?
  ad              String?
  keyword         String?
  city            String?
  state           String?
  country         String?  @default("BR")
  productInterest String?
  estimatedValue  Decimal? @db.Decimal(12, 2)
  campaignId      String?
  valueInvested   Decimal? @db.Decimal(12, 2)
  notes_internal  String?
  tagsJson        String?
  customFields    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaignRef Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  revenueSales RevenueSale[]
  attendances  Attendance[]
  attendanceHistoryEntries AttendanceHistory[]
  reminders    Reminder[]
  followUps    FollowUp[]
  saleResults  SaleResult[]

  @@unique([companyId, email, phone])
  @@index([companyId])
  @@index([source])
  @@index([campaign])
  @@index([createdAt])
}

// --- Vendas (Financeiro) ---

model Sale {
  id            String    @id @default(cuid())
  companyId     String
  amount        Decimal   @db.Decimal(12, 2)
  profit        Decimal?  @db.Decimal(12, 2)
  commission    Decimal?  @db.Decimal(12, 2)
  source        String    @default("manual")
  campaignId    String?
  paymentMethod String?
  paymentStatus String    @default("pending")
  productName   String?
  quantity      Int?      @default(1)
  notes         String?
  customFields  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([source])
  @@index([paymentStatus])
  @@index([createdAt])
}

// --- Integrações ---

model CompanyIntegration {
  id            String    @id @default(cuid())
  companyId     String
  type          String
  name          String
  status        String    @default("disconnected")
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  webhookSecret String?
  config        Json?
  lastSyncAt    DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  testedAt      DateTime?
  connectedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
  @@index([companyId])
  @@index([status])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum WorkflowTriggerType {
  MANUAL
  SCHEDULED
  EVENT
  WEBHOOK
}

enum WorkflowActionType {
  NOTIFICATION
  TASK
  RECORD_UPDATE
  WEBHOOK
  INTEGRATION_CALL
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

model Workflow {
  id          String              @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      WorkflowStatus      @default(DRAFT)
  triggerType WorkflowTriggerType
  config      Json?
  metadata    Json?
  version     Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  triggers    WorkflowTrigger[]
  actions     WorkflowAction[]
  executions  WorkflowExecution[]

  @@index([companyId])
  @@index([status])
  @@index([triggerType])
}

model WorkflowTrigger {
  id             String              @id @default(cuid())
  workflowId     String
  triggerType    WorkflowTriggerType
  config         Json
  isActive       Boolean             @default(true)
  lastTriggeredAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  workflow       Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([triggerType])
  @@index([isActive])
}

model WorkflowAction {
  id          String              @id @default(cuid())
  workflowId  String
  actionType  WorkflowActionType
  config      Json
  "order"    Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workflow    Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([actionType])
  @@index([isActive])
}

model WorkflowTemplate {
  id           String              @id @default(cuid())
  companyId    String
  name         String
  description  String?
  version      Int                 @default(1)
  triggerType  WorkflowTriggerType
  category     String?
  templateData Json
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([triggerType])
  @@index([isActive])
}

model WorkflowExecution {
  id           String                 @id @default(cuid())
  workflowId   String
  companyId    String
  status       WorkflowExecutionStatus @default(PENDING)
  triggerType  WorkflowTriggerType
  triggeredBy  String?
  triggerData  Json?
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  result       Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  workflow     Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  logs         WorkflowExecutionLog[]
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([workflowId])
  @@index([status])
}

model WorkflowExecutionLog {
  id          String   @id @default(cuid())
  executionId String
  companyId   String
  eventType   String
  message     String?
  payload     Json?
  createdAt   DateTime @default(now())

  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([executionId])
  @@index([eventType])
  @@index([createdAt])
}

// --- WhatsApp ---

model WhatsAppConversation {
  id                  String    @id @default(cuid())
  companyId           String
  phoneNumber         String
  status              String    @default("open")
  lastMessageAt       DateTime?
  averageResponseTime Int?
  notes               String?
  customFields        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@unique([companyId, phoneNumber])
  @@index([companyId])
  @@index([status])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  externalId     String?
  type           String?
  mediaUrl       String?
  sentiment      String?
  hasObjection   Boolean?
  createdAt      DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

// --- Auditoria ---

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  userId        String?
  companyUserId String?
  action        String
  resource      String
  resourceId    String?
  changes       Json?
  description   String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyUser CompanyUser? @relation(fields: [companyUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

// --- IA Autônoma para Leads ---

model CompanyKnowledge {
  id                String    @id @default(cuid())
  companyId         String    @unique

  // Website
  websiteUrl        String?
  websiteContent    String?   @db.Text

  // Instagram
  instagramHandle   String?
  instagramBio      String?
  instagramPosts    Json?

  // Produtos/Serviços
  products          Json?
  services          Json?

  // Informações-chave
  mission           String?   @db.Text
  values            Json?
  history           String?   @db.Text
  locations         Json?

  // Horários e contato
  businessHours     Json?
  phone             String?
  email             String?

  // Embedding para busca
  knowledgeEmbedding String? @db.Text

  // Rastreamento
  lastScrapedAt     DateTime?
  scrapedFrom       String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model LeadInteraction {
  id                String    @id @default(cuid())
  companyId         String

  sourceType        String
  leadEmail         String?
  leadPhone         String?
  leadName          String?

  messageReceived   String    @db.Text
  aiResponse        String    @db.Text

  actionTaken       String
  qualificationScore Int?
  resultType        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sourceType])
  @@index([resultType])
  @@index([createdAt])
}

// ==================================================================================
// MASTER 06: REVENUE ENGINE - Inteligência de Receita
// ==================================================================================

enum RevenueSaleStatus {
  NOVO
  EM_ATENDIMENTO
  AGUARDANDO
  VENDA_REALIZADA
  VENDA_PERDIDA
  CANCELADO
  POS_VENDA
}

enum RevenueSourceType {
  META
  GOOGLE
  TIKTOK
  SHOPEE
  LINKEDIN
  PINTEREST
  ORGANIC
  DIRECT
  REFERRAL
  OTHER
}

enum RevenueLossReasonType {
  PRECO
  CONCORRENTE
  SEM_INTERESSE
  SEM_RETORNO
  SEM_ESTOQUE
  PRAZO
  OUTRO
}

// --- Revenue Sales: Vendas com histórico completo ---
model RevenueSale {
  id                String                @id @default(cuid())
  companyId         String
  leadId            String?
  campaignId        String?
  saleSourceId      String?

  status            RevenueSaleStatus     @default(NOVO)

  // Cliente
  clientName        String
  clientPhone       String?
  clientEmail       String?

  // Valor e Produtos
  totalAmount       Decimal               @db.Decimal(12, 2)
  products          Json // array de {id, name, quantity, unitPrice, totalPrice}

  // Atendimento
  attendantId       String? // userId que atendeu
  attendantName     String?

  // Pagamento
  paymentMethod     String?
  paymentStatus     String                @default("pending")
  paymentDate       DateTime?

  // Custos e Margem
  totalCost         Decimal?              @db.Decimal(12, 2) // custo dos produtos
  advertisingCost   Decimal?              @db.Decimal(12, 2) // custo do anúncio
  otherCosts        Decimal?              @db.Decimal(12, 2) // outros custos
  profitAmount      Decimal?              @db.Decimal(12, 2) // lucro bruto
  profitMargin      Decimal?              @db.Decimal(5, 2) // % margem

  // Se perdida
  lossReasonId      String?
  lossNotes         String?
  valueLost         Decimal?              @db.Decimal(12, 2)

  // Observações e Metadados
  notes             String?
  customFields      Json?

  saleDate          DateTime              @default(now())
  saleTime          String? // HH:MM formato
  completedAt       DateTime?
  canceledAt        DateTime?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead              Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign          Campaign?             @relation("RevenueSalesToCampaign", fields: [campaignId], references: [id], onDelete: SetNull)
  source            RevenueSource?        @relation(fields: [saleSourceId], references: [id], onDelete: SetNull)
  lossReason        RevenueLossReason?    @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)

  timeline          RevenueTimeline[]
  commissions       RevenueCommission[]

  @@index([companyId])
  @@index([status])
  @@index([saleSourceId])
  @@index([campaignId])
  @@index([paymentStatus])
  @@index([saleDate])
  @@index([companyId, saleDate])
  @@index([companyId, status])
}

// --- Revenue Source: Origem de vendas ---
model RevenueSource {
  id                String                @id @default(cuid())
  companyId         String

  sourceType        RevenueSourceType
  displayName       String
  description       String?
  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales             RevenueSale[]

  @@unique([companyId, sourceType])
  @@index([companyId])
}

// --- Revenue Product: Produtos com margem ---
model RevenueProduct {
  id                String                @id @default(cuid())
  companyId         String

  name              String
  description       String?
  sku               String?
  category          String?

  basePrice         Decimal               @db.Decimal(12, 2)
  costPrice         Decimal?              @db.Decimal(12, 2)
  marginPercent     Decimal?              @db.Decimal(5, 2)

  commissionType    String?               // fixed, percentage
  commissionAmount  Decimal?              @db.Decimal(12, 2)

  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
}

// --- Revenue Loss Reason: Motivos de perda ---
model RevenueLossReason {
  id                String                @id @default(cuid())
  companyId         String

  reason            RevenueLossReasonType
  description       String?
  displayOrder      Int                   @default(0)
  isActive          Boolean               @default(true)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales             RevenueSale[]

  @@unique([companyId, reason])
  @@index([companyId])
}

// --- Revenue Timeline: Histórico completo de cada venda ---
model RevenueTimeline {
  id                String                @id @default(cuid())
  companyId         String
  saleId            String

  eventType         String // lead_created, first_contact, stage_changed, sale_completed, etc
  eventDescription  String

  previousValue     String?
  newValue          String?

  userId            String? // quem fez a ação
  userEmail         String?

  createdAt         DateTime              @default(now())

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale              RevenueSale           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([saleId])
  @@index([eventType])
  @@index([createdAt])
}

// --- Revenue Indicator: KPIs calculados ---
model RevenueIndicator {
  id                String                @id @default(cuid())
  companyId         String

  period            String                // day, week, month, quarter, year
  date              DateTime              @db.Date

  // Investimento
  totalInvestment   Decimal               @db.Decimal(12, 2)

  // Vendas
  totalRevenue      Decimal               @db.Decimal(12, 2)
  totalSales        Int
  avgTicket         Decimal               @db.Decimal(12, 2)

  // Custos e Lucro
  totalCost         Decimal?              @db.Decimal(12, 2)
  totalProfit       Decimal?              @db.Decimal(12, 2)
  profitMargin      Decimal?              @db.Decimal(5, 2)

  // Conversão
  totalLeads        Int
  conversionRate    Decimal               @db.Decimal(5, 2) // %

  // KPIs
  roas              Decimal               @db.Decimal(10, 2)
  roi               Decimal               @db.Decimal(10, 2) // %
  cac               Decimal               @db.Decimal(12, 2)
  cpa               Decimal               @db.Decimal(12, 2)
  ltv               Decimal?              @db.Decimal(12, 2)

  // Segmentação
  channel           String?
  campaignId        String?
  productId         String?
  attendantId       String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, period, date, channel, campaignId, productId, attendantId])
  @@index([companyId])
  @@index([date])
  @@index([companyId, date])
  @@index([channel])
  @@index([campaignId])
}

// --- Revenue Goal: Metas ---
model RevenueGoal {
  id                String                @id @default(cuid())
  companyId         String

  name              String
  description       String?

  metricType        String // revenue, sales, roas, roi, etc
  targetValue       Decimal               @db.Decimal(12, 2)
  currentValue      Decimal               @db.Decimal(12, 2) @default(0)

  progressPercent   Decimal               @db.Decimal(5, 2) @default(0)

  startDate         DateTime
  endDate           DateTime
  status            String                @default("active") // active, completed, missed

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([metricType])
}

// --- Revenue Forecast: Projeções ---
model RevenueForecast {
  id                String                @id @default(cuid())
  companyId         String

  forecastDate      DateTime              @db.Date
  projectedRevenue  Decimal               @db.Decimal(12, 2)
  projectedSales    Int
  projectedProfit   Decimal?              @db.Decimal(12, 2)

  confidence        Decimal               @db.Decimal(3, 0) // 0-100%
  notes             String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([forecastDate])
}

// --- Revenue Commission: Comissões ---
model RevenueCommission {
  id                String                @id @default(cuid())
  companyId         String
  saleId            String

  attendantId       String?
  attendantName     String?

  commissionType    String // fixed, percentage
  commissionAmount  Decimal               @db.Decimal(12, 2)

  status            String                @default("pending") // pending, calculated, paid
  paidAt            DateTime?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale              RevenueSale           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([saleId])
}

// --- Revenue Score: Score para ranking ---
model RevenueScore {
  id                String                @id @default(cuid())
  companyId         String

  scoreType         String // campaign, product, attendant, channel
  targetId          String // campaign.id, product.id, etc

  score             Decimal               @db.Decimal(5, 2) // 0-100

  // Métrica base
  baseMetric        String // revenue, profit, roas, roi, etc
  baseValue         Decimal               @db.Decimal(12, 2)

  rank              Int?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, scoreType, targetId])
  @@index([companyId])
  @@index([scoreType])
}
